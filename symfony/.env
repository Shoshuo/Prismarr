# Prismarr — default values.
# Actual sensitive values (API keys) go in .env.local (never committed).

###> symfony/framework-bundle ###
APP_ENV=prod
APP_SECRET=change_me_in_env_local
APP_SHARE_DIR=var/share
# Reverse-proxy support (Traefik, nginx, Caddy, Cloudflare Tunnel...).
# "REMOTE_ADDR" is a Symfony placeholder = trust the immediate upstream proxy.
# Combined with 127.0.0.1 it covers local + docker-network reverse-proxies.
# Restrict further in .env.local if your proxy sits on a known IP range.
TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost:7070
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# SQLite by default — zero-config, file in var/data/prismarr.db
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data/prismarr.db"
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_in_env_local
###< lexik/jwt-authentication-bundle ###

###> symfony/mercure-bundle ###
MERCURE_URL=http://localhost:7070/.well-known/mercure
MERCURE_PUBLIC_URL=http://localhost:7070/.well-known/mercure
MERCURE_JWT_SECRET=change_me_in_env_local
###< symfony/mercure-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default
###< symfony/messenger ###

###> Prismarr UI ###
PRISMARR_PRIMARY_COLOR=#6366f1
PRISMARR_LOGO_URL=
###< Prismarr UI ###

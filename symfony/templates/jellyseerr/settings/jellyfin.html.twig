{% extends 'base.html.twig' %}
{% block title %}Jellyfin — {{ 'jellyseerr.nav.settings'|trans }}{% endblock %}
{% block page_title %}<svg width="24" height="24" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg"><path d="M256 48C141.1 48 48 141.1 48 256s93.1 208 208 208 208-93.1 208-208S370.9 48 256 48zm0 368c-88.4 0-160-71.6-160-160S167.6 96 256 96s160 71.6 160 160-71.6 160-160 160z" fill="#a259ff"/><circle cx="256" cy="256" r="80" fill="#a259ff"/></svg> {{ 'jellyseerr.settings.jellyfin.title'|trans }}{% endblock %}
{% block head_meta %}<meta name="turbo-visit-control" content="reload">{% endblock %}

{% block stylesheets %}
<style>
.js-setting-item { padding:.85rem 1.25rem; }
.js-setting-item .js-label { font-weight:600; font-size:.88rem; }
.js-setting-item .js-desc { font-size:.75rem; color:var(--tblr-text-secondary); margin-top:1px; }
.js-section-header { background:var(--tblr-bg-surface-secondary); padding:.5rem 1.25rem; }
.js-section-header span { font-weight:700; font-size:.75rem; text-transform:uppercase; letter-spacing:.5px; color:#a259ff; }
.js-lib-item { display:flex; align-items:center; justify-content:space-between; padding:.65rem .85rem; background:var(--tblr-bg-surface-secondary); border-radius:.5rem; margin-bottom:.4rem; transition:all .15s; }
.js-lib-item:hover { background:rgba(162,89,255,.05); }
</style>
{% endblock %}

{% block body %}
<div class="container-xl py-2">
    <div class="d-flex align-items-center justify-content-end">{% include 'jellyseerr/_nav.html.twig' %}</div>
</div>
<div class="page-body"><div class="container-xl">

<div class="alert alert-warning d-flex align-items-start gap-2 mb-3" style="font-size:.82rem;">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;margin-top:1px;"><path d="M12 9v4"/><path d="M10.363 3.591l-8.106 13.534a1.914 1.914 0 0 0 1.636 2.871h16.214a1.914 1.914 0 0 0 1.636 -2.871l-8.106 -13.534a1.914 1.914 0 0 0 -3.274 0z"/><path d="M12 16h.01"/></svg>
    <div>{{ 'jellyseerr.settings.jellyfin.readonly_warning_html'|trans|replace({'__URL__': service_url ~ '/settings/jellyfin'})|raw }}</div>
</div>

{# ── Libraries ── #}
<div class="card mb-4">
    <div class="card-header d-flex align-items-center justify-content-between">
        <h3 class="card-title">
            <svg width="18" height="18" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg" class="me-2" style="vertical-align:-3px;"><path d="M256 96c-88.4 0-160 71.6-160 160s71.6 160 160 160 160-71.6 160-160S344.4 96 256 96z" fill="#00A4DC"/></svg>
            {{ 'jellyseerr.settings.jellyfin.libraries_title'|trans }}
        </h3>
        <a href="{{ service_url }}/settings/jellyfin" target="_blank" class="btn btn-sm btn-outline-info">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 6h-6a2 2 0 0 0 -2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-6"/><path d="M11 13l9 -9"/><path d="M15 4h5v5"/></svg>
            {{ 'jellyseerr.settings.jellyfin.manage_in_jellyseerr'|trans }}
        </a>
    </div>
    <div class="card-body">
        {% for lib in jellyfin.libraries ?? [] %}
            <div class="js-lib-item">
                <div class="d-flex align-items-center gap-2">
                    {% if lib.type == 'movie' %}
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="2"/><circle cx="8" cy="8" r="2"/><path d="M2 14l6 -6l12 12"/></svg>
                    {% else %}
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#38bdf8" stroke-width="2"><rect x="2" y="7" width="20" height="15" rx="2"/><path d="M17 2l-5 5l-5 -5"/></svg>
                    {% endif %}
                    <div>
                        <span style="font-weight:600;font-size:.88rem;">{{ lib.name ?? '?' }}</span>
                        <span class="badge bg-{{ lib.type == 'movie' ? 'red' : 'cyan' }}-lt text-{{ lib.type == 'movie' ? 'red' : 'cyan' }} ms-2" style="font-size:.6rem;">{{ lib.type == 'movie' ? 'jellyseerr.settings.jellyfin.lib_movies'|trans : 'jellyseerr.settings.jellyfin.lib_tv'|trans }}</span>
                    </div>
                </div>
                <label class="form-check form-switch mb-0">
                    <input type="checkbox" class="form-check-input" {{ lib.enabled ?? false ? 'checked' }} disabled style="width:2.2rem;height:1.1rem;cursor:default;">
                </label>
            </div>
        {% endfor %}
        {% if (jellyfin.libraries ?? [])|length == 0 %}
            <div class="text-secondary text-center py-2">{{ 'jellyseerr.settings.jellyfin.no_library'|trans }}</div>
        {% endif %}
    </div>
</div>

{# ── Analyse manuelle ── #}
<div class="card mb-4">
    <div class="card-header"><h3 class="card-title">{{ 'jellyseerr.settings.jellyfin.manual_scan_title'|trans }}</h3></div>
    <div class="card-body">
        <p class="text-secondary" style="font-size:.82rem;">{{ 'jellyseerr.settings.jellyfin.manual_scan_desc'|trans }}</p>
        <a href="{{ service_url }}/settings/jellyfin" target="_blank" class="btn btn-sm btn-primary" style="background:#a259ff;border-color:#a259ff;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 11a8.1 8.1 0 0 0 -15.5 -2m-.5 -4v4h4"/><path d="M4 13a8.1 8.1 0 0 0 15.5 2m.5 4v-4h-4"/></svg>
            {{ 'jellyseerr.settings.jellyfin.run_scan'|trans }}
        </a>
    </div>
</div>

{# ── Jellyfin settings ── #}
<div class="card">
    <div class="card-header"><h3 class="card-title">{{ 'jellyseerr.settings.jellyfin.settings_title'|trans }}</h3></div>
    <div class="card-body">
    </div>
    <div class="list-group list-group-flush">
        <div class="list-group-item js-setting-item d-flex align-items-center justify-content-between gap-3">
            <div><div class="js-label">{{ 'jellyseerr.settings.jellyfin.internal_name'|trans }}</div></div>
            <div style="width:45%;"><input type="text" class="form-control form-control-sm" value="{{ jellyfin.name ?? '' }}" disabled></div>
        </div>

        <div class="list-group-item js-setting-item d-flex align-items-center justify-content-between gap-3">
            <div><div class="js-label">{{ 'jellyseerr.settings.jellyfin.ip_hostname'|trans }}</div></div>
            <div style="width:45%;">
                <div class="input-group input-group-sm">
                    <input type="text" class="form-control form-control-sm" value="{{ jellyfin.ip ?? '' }}" disabled>
                    <span class="input-group-text">:</span>
                    <input type="text" class="form-control form-control-sm" value="{{ jellyfin.port ?? '' }}" disabled style="max-width:80px;">
                </div>
            </div>
        </div>

        <div class="list-group-item js-setting-item d-flex align-items-center justify-content-between gap-3">
            <div><div class="js-label">{{ 'jellyseerr.settings.jellyfin.tls_label'|trans }}</div></div>
            <label class="form-check form-switch mb-0"><input type="checkbox" class="form-check-input" {{ jellyfin.useSsl ?? false ? 'checked' }} disabled style="width:2.2rem;height:1.1rem;cursor:default;"></label>
        </div>

        <div class="list-group-item js-setting-item d-flex align-items-center justify-content-between gap-3">
            <div><div class="js-label">{{ 'jellyseerr.settings.jellyfin.api_key'|trans }}</div></div>
            <div style="width:45%;">
                <div class="input-group input-group-sm">
                    <input type="password" class="form-control form-control-sm" id="js-jf-api" value="{{ jellyfin.apiKey ?? '' }}" disabled>
                    <button class="btn btn-outline-secondary btn-sm" id="js-jf-toggle" title="{{ 'jellyseerr.settings.jellyfin.show'|trans }}"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/><path d="M21 12c-2.4 4-5.4 6-9 6c-3.6 0-6.6-2-9-6c2.4-4 5.4-6 9-6c3.6 0 6.6 2 9 6"/></svg></button>
                    <button class="btn btn-outline-secondary btn-sm" id="js-jf-copy" title="{{ 'jellyseerr.settings.jellyfin.copy'|trans }}"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15h-2a2 2 0 0 1 -2 -2v-9a2 2 0 0 1 2 -2h9a2 2 0 0 1 2 2v2"/></svg></button>
                </div>
            </div>
        </div>

        <div class="list-group-item js-setting-item d-flex align-items-center justify-content-between gap-3">
            <div><div class="js-label">{{ 'jellyseerr.settings.jellyfin.base_url'|trans }}</div><div class="js-desc">{{ 'jellyseerr.settings.jellyfin.base_url_desc'|trans }}</div></div>
            <div style="width:45%;"><input type="text" class="form-control form-control-sm" value="{{ jellyfin.urlBase ?? '' }}" disabled placeholder="{{ 'jellyseerr.settings.jellyfin.not_configured'|trans }}"></div>
        </div>

        <div class="list-group-item js-setting-item d-flex align-items-center justify-content-between gap-3">
            <div><div class="js-label">{{ 'jellyseerr.settings.jellyfin.external_url'|trans }}</div><div class="js-desc">{{ 'jellyseerr.settings.jellyfin.external_url_desc'|trans }}</div></div>
            <div style="width:45%;"><input type="text" class="form-control form-control-sm" value="{{ jellyfin.externalHostname ?? '' }}" disabled></div>
        </div>

        <div class="list-group-item js-setting-item d-flex align-items-center justify-content-between gap-3">
            <div><div class="js-label">{{ 'jellyseerr.settings.jellyfin.forgot_password_url'|trans }}</div><div class="js-desc">{{ 'jellyseerr.settings.jellyfin.forgot_password_url_desc'|trans }}</div></div>
            <div style="width:45%;"><input type="text" class="form-control form-control-sm" value="{{ jellyfin.jellyfinForgotPasswordUrl ?? '' }}" disabled placeholder="{{ 'jellyseerr.settings.jellyfin.not_configured'|trans }}"></div>
        </div>

        <div class="list-group-item js-setting-item d-flex align-items-center justify-content-between gap-3">
            <div><div class="js-label">{{ 'jellyseerr.settings.jellyfin.server_id'|trans }}</div></div>
            <div style="width:45%;"><input type="text" class="form-control form-control-sm" value="{{ jellyfin.serverId ?? '' }}" disabled style="font-family:monospace;font-size:.75rem;"></div>
        </div>
    </div>
</div>

</div></div>
{% endblock %}

{% block javascripts %}
<script>
(function(){
    // API key toggle/copy
    var jfApi = document.getElementById('js-jf-api');
    var jfToggle = document.getElementById('js-jf-toggle');
    var jfCopy = document.getElementById('js-jf-copy');
    if (jfToggle) jfToggle.addEventListener('click', function(){ jfApi.type = jfApi.type === 'password' ? 'text' : 'password'; });
    if (jfCopy) jfCopy.addEventListener('click', function(){
        var orig = jfApi.type; jfApi.type = 'text'; jfApi.select(); document.execCommand('copy'); jfApi.type = orig;
        this.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5"><path d="M5 12l5 5l10 -10"/></svg>';
        var self = this; setTimeout(function(){ self.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15h-2a2 2 0 0 1 -2 -2v-9a2 2 0 0 1 2 -2h9a2 2 0 0 1 2 2v2"/></svg>'; }, 2000);
    });



})();
</script>
{% endblock %}

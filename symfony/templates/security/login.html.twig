<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"/>
  <title>Connexion — Prismarr</title>

  <link rel="icon" type="image/x-icon" href="{{ asset('img/prismarr/favicon.ico') }}"/>
  <link rel="icon" type="image/png" sizes="192x192" href="{{ asset('img/prismarr/favicon-192.png') }}"/>
  <link rel="apple-touch-icon" href="{{ asset('img/prismarr/prismarr-icon-512.png') }}"/>

  <script>
    (function () {
      var t = localStorage.getItem('tablerTheme') || 'dark';
      document.documentElement.setAttribute('data-bs-theme', t);
    })();
  </script>

  <link rel="stylesheet" href="{{ asset('static/tabler/css/tabler.min.css') }}"/>
  <link rel="stylesheet" href="{{ asset('static/tabler/css/tabler-themes.min.css') }}"/>

  <style>
    @import url("https://rsms.me/inter/inter.css");

    :root {
      --tblr-primary: #6366f1;
      --tblr-primary-rgb: 99, 102, 241;
      --tblr-font-family-sans-serif: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    html, body { min-height: 100%; }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    [data-bs-theme="dark"] body  { background-color: #111111 !important; color: #e4e4e7; }
    [data-bs-theme="light"] body { background-color: #f4f6fb !important; }

    .login-wrapper {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem 1.5rem;
    }

    .login-box { width: 100%; max-width: 400px; }

    .login-logo {
      text-align: center;
      margin-bottom: 1.75rem;
    }
    .login-logo img { height: 96px; display: block; margin: 0 auto; }

    .login-card {
      background: #1c1c1c;
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 12px;
      padding: 1.75rem;
      box-shadow: 0 2px 16px rgba(0,0,0,.35);
    }
    [data-bs-theme="light"] .login-card {
      background: #ffffff;
      border-color: rgba(0,0,0,.08);
      box-shadow: 0 1px 8px rgba(0,0,0,.06);
    }

    .login-title {
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 1.25rem;
      letter-spacing: -0.01em;
    }

    .form-label {
      font-size: .78rem;
      font-weight: 500;
      letter-spacing: .02em;
      opacity: .75;
    }

    .form-control, .input-group-text {
      background: rgba(255,255,255,.03);
      border: 1px solid rgba(255,255,255,.09);
      border-radius: 8px;
      padding: .6rem .8rem;
      color: inherit;
      transition: all .15s ease;
    }
    [data-bs-theme="light"] .form-control,
    [data-bs-theme="light"] .input-group-text {
      background: rgba(0,0,0,.02);
      border-color: rgba(0,0,0,.1);
    }

    .form-control:focus {
      background: rgba(99, 102, 241, 0.05);
      border-color: rgba(99, 102, 241, 0.55);
      box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.12);
      color: inherit;
    }

    .input-group.input-group-flat .form-control { border-right: 0 !important; }
    .input-group.input-group-flat .input-group-text {
      border-left: 0 !important;
      background: rgba(255, 255, 255, .03) !important;
      border-color: rgba(255, 255, 255, .09) !important;
      color: inherit;
    }
    [data-bs-theme="light"] .input-group.input-group-flat .input-group-text {
      background: rgba(0, 0, 0, .02) !important;
      border-color: rgba(0, 0, 0, .1) !important;
    }
    .input-group.input-group-flat .form-control:focus {
      box-shadow: none;
    }
    .input-group.input-group-flat:focus-within {
      border-radius: 8px;
      box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.12) !important;
    }
    .input-group.input-group-flat:focus-within .form-control,
    .input-group.input-group-flat:focus-within .input-group-text {
      border-color: rgba(99, 102, 241, 0.55) !important;
    }
    .password-toggle,
    .password-toggle:hover,
    .password-toggle:focus,
    .password-toggle:active,
    .password-toggle:visited {
      color: rgba(255, 255, 255, .75) !important;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      background: transparent !important;
      background-color: transparent !important;
      box-shadow: none !important;
      outline: none !important;
      transition: color .15s ease;
    }
    .password-toggle:hover { color: #ffffff !important; }
    .password-toggle svg { stroke: currentColor; }
    [data-bs-theme="light"] .password-toggle,
    [data-bs-theme="light"] .password-toggle:focus,
    [data-bs-theme="light"] .password-toggle:active {
      color: rgba(0, 0, 0, .65) !important;
    }
    [data-bs-theme="light"] .password-toggle:hover {
      color: #000000 !important;
    }

    .btn-login {
      background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
      border: none;
      border-radius: 8px;
      padding: .65rem 1rem;
      font-weight: 500;
      color: #fff;
      box-shadow: 0 2px 10px rgba(99, 102, 241, 0.3);
      transition: all .2s ease;
    }
    .btn-login:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 16px rgba(99, 102, 241, 0.45);
      color: #fff;
    }
    .btn-login:active { transform: translateY(0); }

    .alert-danger {
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.25);
      color: #fca5a5;
      border-radius: 8px;
      font-size: .85rem;
    }
    [data-bs-theme="light"] .alert-danger { color: #991b1b; }

    .login-footer {
      text-align: center;
      margin-top: 1.5rem;
      font-size: .75rem;
      opacity: .4;
    }

    .theme-toggle {
      position: fixed;
      top: 1rem;
      right: 1rem;
      z-index: 10;
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.08);
      color: inherit;
      width: 36px;
      height: 36px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all .15s ease;
    }
    .theme-toggle:hover { background: rgba(255,255,255,.08); }
    [data-bs-theme="light"] .theme-toggle { background: rgba(0,0,0,.04); border-color: rgba(0,0,0,.08); }
    [data-bs-theme="light"] .theme-toggle:hover { background: rgba(0,0,0,.08); }
    .theme-toggle .icon-moon { display: inline; }
    .theme-toggle .icon-sun  { display: none; }
    [data-bs-theme="light"] .theme-toggle .icon-moon { display: none; }
    [data-bs-theme="light"] .theme-toggle .icon-sun  { display: inline; }
  </style>
</head>
<body>

  <button type="button" class="theme-toggle" id="theme-toggle" title="Changer de thème">
    <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313 -12.454z"/>
    </svg>
    <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="4"/>
      <path d="M3 12h1m8 -9v1m8 8h1m-9 8v1m-6.4 -15.4l.7 .7m12.1 -.7l-.7 .7m0 11.4l.7 .7m-12.1 -.7l-.7 .7"/>
    </svg>
  </button>

  <div class="login-wrapper">
    <div class="login-box">

      <div class="login-logo">
        <img src="{{ asset('img/prismarr/prismarr-logo-horizontal.png') }}" alt="Prismarr"/>
      </div>

      {% if error %}
        <div class="alert alert-danger mb-3">
          {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
      {% endif %}

      <div class="login-card">
        <div class="login-title">Connexion</div>

        <form action="{{ path('app_login') }}" method="post" autocomplete="off" novalidate>
          <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}"/>

          <div class="mb-3">
            <label class="form-label" for="email">Adresse email</label>
            <input type="email" id="email" name="_username" class="form-control"
                   placeholder="votre@email.com"
                   value="{{ last_username }}"
                   autocomplete="email" autofocus required/>
          </div>

          <div class="mb-3">
            <label class="form-label" for="password">Mot de passe</label>
            <div class="input-group input-group-flat">
              <input type="password" id="password" name="_password" class="form-control"
                     placeholder="••••••••" autocomplete="current-password" required/>
              <span class="input-group-text">
                <a href="#" class="password-toggle" id="toggle-password" title="Afficher le mot de passe">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                       fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/>
                    <path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/>
                  </svg>
                </a>
              </span>
            </div>
          </div>

          <div class="mb-4">
            <label class="form-check">
              <input type="checkbox" name="_remember_me" class="form-check-input" checked/>
              <span class="form-check-label">Se souvenir de moi (7 jours)</span>
            </label>
          </div>

          <button type="submit" class="btn btn-login w-100">Se connecter</button>
        </form>
      </div>

      <div class="login-footer">
        Prismarr &copy; {{ "now"|date("Y") }} · AGPLv3
      </div>

    </div>
  </div>

  <script>
    document.getElementById('toggle-password').addEventListener('click', function(e) {
      e.preventDefault();
      var input = document.getElementById('password');
      input.type = input.type === 'password' ? 'text' : 'password';
    });

    document.getElementById('theme-toggle').addEventListener('click', function() {
      var current = document.documentElement.getAttribute('data-bs-theme');
      var next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-bs-theme', next);
      localStorage.setItem('tablerTheme', next);
    });
  </script>
</body>
</html>

{% extends 'base.html.twig' %}

{% block title %}{{ 'media.arr_admin.media_management.title_radarr'|trans }}{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">{{ 'media.arr_admin.media_management.page_title'|trans }}</h2>
      </div>
      <div class="col-auto ms-auto">
        {% include 'media/_radarr_nav.html.twig' %}
      </div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
<div class="alert alert-danger">{{ 'media.arr_admin.media_management.error_unreachable_radarr'|trans }}</div>
{% endif %}

<div id="mm-feedback" class="alert d-none mb-3"></div>

{# ══════════════════════════════════════════════════════════════════════════
   Section A: File naming
   ══════════════════════════════════════════════════════════════════════════ #}
{% if namingConfig %}
<div class="card mb-4">
  <div class="card-header">
    <h3 class="card-title">{{ 'media.arr_admin.media_management.naming.title_radarr'|trans }}</h3>
  </div>
  <div class="card-body">
    <form id="form-naming" class="row g-3">
      <div class="col-sm-6 col-md-3">
        <div class="form-check mt-2">
          <input class="form-check-input" type="checkbox" name="renameMovies" id="renameMovies" {{ namingConfig.renameMovies ?? false ? 'checked' }}>
          <label class="form-check-label" for="renameMovies">{{ 'media.arr_admin.media_management.naming.rename_movies'|trans }}</label>
        </div>
      </div>
      <div class="col-sm-6 col-md-3">
        <div class="form-check mt-2">
          <input class="form-check-input" type="checkbox" name="replaceIllegalCharacters" id="replaceIllegalCharacters" {{ namingConfig.replaceIllegalCharacters ?? false ? 'checked' }}>
          <label class="form-check-label" for="replaceIllegalCharacters">{{ 'media.arr_admin.media_management.naming.replace_illegal'|trans }}</label>
        </div>
      </div>
      <div class="col-sm-6 col-md-3">
        <label class="form-label">{{ 'media.arr_admin.media_management.naming.colon_replacement'|trans }}</label>
        <select name="colonReplacementFormat" class="form-select">
          <option value="smart" {{ (namingConfig.colonReplacementFormat ?? '') == 'smart' ? 'selected' }}>{{ 'media.arr_admin.media_management.naming.colon_smart'|trans }}</option>
          <option value="dash" {{ (namingConfig.colonReplacementFormat ?? '') == 'dash' ? 'selected' }}>{{ 'media.arr_admin.media_management.naming.colon_dash'|trans }}</option>
          <option value="spaceDash" {{ (namingConfig.colonReplacementFormat ?? '') == 'spaceDash' ? 'selected' }}>{{ 'media.arr_admin.media_management.naming.colon_space_dash'|trans }}</option>
          <option value="spaceDashSpace" {{ (namingConfig.colonReplacementFormat ?? '') == 'spaceDashSpace' ? 'selected' }}>{{ 'media.arr_admin.media_management.naming.colon_space_dash_space'|trans }}</option>
        </select>
      </div>
      <div class="col-sm-12 col-md-6">
        <label class="form-label">{{ 'media.arr_admin.media_management.naming.movie_format'|trans }}</label>
        <input type="text" name="standardMovieFormat" class="form-control" value="{{ namingConfig.standardMovieFormat ?? '' }}">
      </div>
      <div class="col-sm-12 col-md-6">
        <label class="form-label">{{ 'media.arr_admin.media_management.naming.movie_folder_format'|trans }}</label>
        <input type="text" name="movieFolderFormat" class="form-control" value="{{ namingConfig.movieFolderFormat ?? '' }}">
      </div>
      <div class="col-12">
        <details class="mt-1">
          <summary class="text-muted small" style="cursor:pointer">{{ 'media.arr_admin.media_management.naming.tokens_summary'|trans }}</summary>
          <div class="mt-2 text-muted small font-monospace">
            {Movie Title} &middot; {Original Title} &middot; {Release Year} &middot; {Quality Full} &middot;
            {Quality Title} &middot; {MediaInfo VideoCodec} &middot; {MediaInfo AudioCodec} &middot;
            {MediaInfo AudioChannels} &middot; {MediaInfo VideoBitDepth} &middot; {MediaInfo VideoDynamicRange} &middot;
            {Release Group} &middot; {Edition Tags} &middot; {Custom Formats} &middot; {Movie CleanTitle}
          </div>
        </details>
      </div>
      <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary" id="btn-save-naming">{{ 'media.arr_admin.media_management.naming.save'|trans }}</button>
        <button type="button" id="btn-naming-preview" class="btn btn-outline-secondary">{{ 'media.arr_admin.media_management.naming.preview'|trans }}</button>
      </div>
    </form>
    <div id="naming-preview" class="mt-3" style="display:none;">
      <div class="table-responsive">
        <table class="table table-sm table-vcenter mb-0" style="font-size:.8rem;">
          <tbody id="naming-preview-tbody"></tbody>
        </table>
      </div>
    </div>
  </div>
</div>
{% endif %}

{# ══════════════════════════════════════════════════════════════════════════
   Section B: Media management
   ══════════════════════════════════════════════════════════════════════════ #}
{% if mmConfig %}
<div class="card mb-4">
  <div class="card-header">
    <h3 class="card-title">{{ 'media.arr_admin.media_management.mm.title'|trans }}</h3>
  </div>
  <div class="card-body">
    <form id="form-mm" class="row g-3">

      {# Checkboxes row #}
      <div class="col-sm-6 col-md-4">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" name="autoUnmonitorPreviouslyDownloadedMovies" id="autoUnmonitor" {{ mmConfig.autoUnmonitorPreviouslyDownloadedMovies ?? false ? 'checked' }}>
          <label class="form-check-label" for="autoUnmonitor">{{ 'media.arr_admin.media_management.mm.auto_unmonitor_movies'|trans }}</label>
        </div>
      </div>
      <div class="col-sm-6 col-md-4">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" name="createEmptyMovieFolders" id="createEmptyFolders" {{ mmConfig.createEmptyMovieFolders ?? false ? 'checked' }}>
          <label class="form-check-label" for="createEmptyFolders">{{ 'media.arr_admin.media_management.mm.create_empty_folders'|trans }}</label>
        </div>
      </div>
      <div class="col-sm-6 col-md-4">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" name="deleteEmptyFolders" id="deleteEmptyFolders" {{ mmConfig.deleteEmptyFolders ?? false ? 'checked' }}>
          <label class="form-check-label" for="deleteEmptyFolders">{{ 'media.arr_admin.media_management.mm.delete_empty_folders'|trans }}</label>
        </div>
      </div>
      <div class="col-sm-6 col-md-4">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" name="autoRenameFolders" id="autoRenameFolders" {{ mmConfig.autoRenameFolders ?? false ? 'checked' }}>
          <label class="form-check-label" for="autoRenameFolders">{{ 'media.arr_admin.media_management.mm.auto_rename_folders'|trans }}</label>
        </div>
      </div>
      <div class="col-sm-6 col-md-4">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" name="copyUsingHardlinks" id="copyHardlinks" {{ mmConfig.copyUsingHardlinks ?? false ? 'checked' }}>
          <label class="form-check-label" for="copyHardlinks">{{ 'media.arr_admin.media_management.mm.copy_hardlinks'|trans }}</label>
        </div>
      </div>
      <div class="col-sm-6 col-md-4">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" name="importExtraFiles" id="importExtraFiles" {{ mmConfig.importExtraFiles ?? false ? 'checked' }}>
          <label class="form-check-label" for="importExtraFiles">{{ 'media.arr_admin.media_management.mm.import_extra_files'|trans }}</label>
        </div>
      </div>
      <div class="col-sm-6 col-md-4">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" name="enableMediaInfo" id="enableMediaInfo" {{ mmConfig.enableMediaInfo ?? false ? 'checked' }}>
          <label class="form-check-label" for="enableMediaInfo">{{ 'media.arr_admin.media_management.mm.enable_mediainfo'|trans }}</label>
        </div>
      </div>
      <div class="col-sm-6 col-md-4">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" name="setPermissionsLinux" id="setPerms" {{ mmConfig.setPermissionsLinux ?? false ? 'checked' }}>
          <label class="form-check-label" for="setPerms">{{ 'media.arr_admin.media_management.mm.set_permissions'|trans }}</label>
        </div>
      </div>

      {# Text / number inputs #}
      <div class="col-sm-6 col-md-4">
        <label class="form-label">{{ 'media.arr_admin.media_management.mm.recycle_bin_path'|trans }}</label>
        <input type="text" name="recycleBin" class="form-control" value="{{ mmConfig.recycleBin ?? '' }}">
      </div>
      <div class="col-sm-6 col-md-4">
        <label class="form-label">{{ 'media.arr_admin.media_management.mm.recycle_bin_cleanup'|trans }}</label>
        <input type="number" name="recycleBinCleanupDays" class="form-control" value="{{ mmConfig.recycleBinCleanupDays ?? 7 }}">
      </div>
      <div class="col-sm-6 col-md-4">
        <label class="form-label">{{ 'media.arr_admin.media_management.mm.min_free_space'|trans }}</label>
        <input type="number" name="minimumFreeSpaceWhenImporting" class="form-control" value="{{ mmConfig.minimumFreeSpaceWhenImporting ?? 100 }}">
      </div>
      <div class="col-sm-6 col-md-4">
        <label class="form-label">{{ 'media.arr_admin.media_management.mm.extra_extensions'|trans }}</label>
        <input type="text" name="extraFileExtensions" class="form-control" value="{{ mmConfig.extraFileExtensions ?? '' }}" placeholder="srt,nfo">
      </div>
      <div class="col-sm-6 col-md-4">
        <label class="form-label">{{ 'media.arr_admin.media_management.mm.chmod_folder'|trans }}</label>
        <input type="text" name="chmodFolder" class="form-control" value="{{ mmConfig.chmodFolder ?? '755' }}">
      </div>
      <div class="col-sm-6 col-md-4">
        <label class="form-label">{{ 'media.arr_admin.media_management.mm.chown_group'|trans }}</label>
        <input type="text" name="chownGroup" class="form-control" value="{{ mmConfig.chownGroup ?? '' }}">
      </div>

      {# Selects #}
      <div class="col-sm-6 col-md-4">
        <label class="form-label">{{ 'media.arr_admin.media_management.mm.propers_repacks'|trans }}</label>
        <select name="downloadPropersAndRepacks" class="form-select">
          <option value="preferAndUpgrade" {{ (mmConfig.downloadPropersAndRepacks ?? '') == 'preferAndUpgrade' ? 'selected' }}>{{ 'media.arr_admin.media_management.mm.prefer_upgrade'|trans }}</option>
          <option value="doNotUpgrade" {{ (mmConfig.downloadPropersAndRepacks ?? '') == 'doNotUpgrade' ? 'selected' }}>{{ 'media.arr_admin.media_management.mm.do_not_upgrade'|trans }}</option>
          <option value="doNotPrefer" {{ (mmConfig.downloadPropersAndRepacks ?? '') == 'doNotPrefer' ? 'selected' }}>{{ 'media.arr_admin.media_management.mm.do_not_prefer'|trans }}</option>
        </select>
      </div>
      <div class="col-sm-6 col-md-4">
        <label class="form-label">{{ 'media.arr_admin.media_management.mm.file_date'|trans }}</label>
        <select name="fileDate" class="form-select">
          <option value="none" {{ (mmConfig.fileDate ?? '') == 'none' ? 'selected' }}>{{ 'media.arr_admin.media_management.mm.file_date_none'|trans }}</option>
          <option value="cinemas" {{ (mmConfig.fileDate ?? '') == 'cinemas' ? 'selected' }}>{{ 'media.arr_admin.media_management.mm.file_date_cinemas'|trans }}</option>
          <option value="release" {{ (mmConfig.fileDate ?? '') == 'release' ? 'selected' }}>{{ 'media.arr_admin.media_management.mm.file_date_release'|trans }}</option>
        </select>
      </div>
      <div class="col-sm-6 col-md-4">
        <label class="form-label">{{ 'media.arr_admin.media_management.mm.rescan_after_refresh'|trans }}</label>
        <select name="rescanAfterRefresh" class="form-select">
          <option value="always" {{ (mmConfig.rescanAfterRefresh ?? '') == 'always' ? 'selected' }}>{{ 'media.arr_admin.media_management.mm.rescan_always'|trans }}</option>
          <option value="afterManual" {{ (mmConfig.rescanAfterRefresh ?? '') == 'afterManual' ? 'selected' }}>{{ 'media.arr_admin.media_management.mm.rescan_after_manual'|trans }}</option>
          <option value="never" {{ (mmConfig.rescanAfterRefresh ?? '') == 'never' ? 'selected' }}>{{ 'media.arr_admin.media_management.mm.rescan_never'|trans }}</option>
        </select>
      </div>

      <div class="col-12">
        <button type="submit" class="btn btn-primary" id="btn-save-mm">{{ 'media.arr_admin.media_management.mm.save_radarr'|trans }}</button>
      </div>
    </form>
  </div>
</div>
{% endif %}

</div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function () {
  var I18N = {
    save: {{ 'media.arr_admin.media_management.save'|trans|json_encode|raw }},
    saving: {{ 'media.arr_admin.media_management.saving'|trans|json_encode|raw }},
    saved: {{ 'media.arr_admin.media_management.saved'|trans|json_encode|raw }},
    errorPrefix: {{ 'media.arr_admin.media_management.error_prefix'|trans|json_encode|raw }},
    errorUnknown: {{ 'media.arr_admin.media_management.error_unknown'|trans|json_encode|raw }},
    errorNetwork: {{ 'media.arr_admin.media_management.error_network'|trans|json_encode|raw }},
    preview: {{ 'media.arr_admin.media_management.naming.preview'|trans|json_encode|raw }},
    loading: {{ 'media.arr_admin.media_management.naming.loading'|trans|json_encode|raw }},
    previewMovie: {{ 'media.arr_admin.media_management.naming.preview_movie'|trans|json_encode|raw }},
    previewMovieFolder: {{ 'media.arr_admin.media_management.naming.preview_movie_folder'|trans|json_encode|raw }},
    previewEmpty: {{ 'media.arr_admin.media_management.naming.preview_empty'|trans|json_encode|raw }}
  };
  var feedbackEl = document.getElementById('mm-feedback');

  function showFeedback(msg, type) {
    feedbackEl.className = 'alert alert-' + (type || 'info') + ' mb-3';
    feedbackEl.textContent = msg;
    feedbackEl.classList.remove('d-none');
    if (type === 'success') setTimeout(function () { feedbackEl.classList.add('d-none'); }, 4000);
  }

  function formToJson(form) {
    var data = {};
    var els = form.elements;
    for (var i = 0; i < els.length; i++) {
      var el = els[i];
      if (!el.name) continue;
      if (el.type === 'checkbox') {
        data[el.name] = el.checked;
      } else if (el.type === 'number') {
        data[el.name] = el.value !== '' ? parseInt(el.value, 10) : 0;
      } else {
        data[el.name] = el.value;
      }
    }
    return data;
  }

  function submitForm(formId, url, btnId) {
    var form = document.getElementById(formId);
    if (!form) return;
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var btn = document.getElementById(btnId);
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> ' + I18N.saving;

      fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify(formToJson(form)),
      })
      .then(function (r) { return r.json(); })
      .then(function (data) {
        btn.disabled = false;
        btn.textContent = I18N.save;
        if (data.ok) {
          showFeedback(I18N.saved, 'success');
        } else {
          showFeedback(I18N.errorPrefix + (data.error || I18N.errorUnknown), 'danger');
        }
      })
      .catch(function () {
        btn.disabled = false;
        btn.textContent = I18N.save;
        showFeedback(I18N.errorNetwork, 'danger');
      });
    });
  }

  submitForm('form-naming', '{{ instance_path("radarr_media_management_naming_save") }}', 'btn-save-naming');
  submitForm('form-mm', '{{ instance_path("radarr_media_management_mm_save") }}', 'btn-save-mm');

  document.getElementById('btn-naming-preview').addEventListener('click', function() {
    var btn = this;
    btn.disabled = true;
    btn.textContent = I18N.loading;
    fetch('{{ instance_path("radarr_media_management_naming_examples") }}', {
      headers: {'X-Requested-With':'XMLHttpRequest'}
    }).then(function(r) { return r.json(); }).then(function(data) {
      btn.disabled = false;
      btn.textContent = I18N.preview;
      var tbody = document.getElementById('naming-preview-tbody');
      var rows = '';
      var labels = {
        movieExample: I18N.previewMovie,
        movieFolderExample: I18N.previewMovieFolder
      };
      for (var key in labels) {
        if (data[key]) {
          rows += '<tr><td class="text-muted" style="width:160px">' + labels[key] + '</td><td class="font-monospace">' + data[key] + '</td></tr>';
        }
      }
      tbody.innerHTML = rows || '<tr><td class="text-muted">' + I18N.previewEmpty + '</td></tr>';
      document.getElementById('naming-preview').style.display = '';
    }).catch(function() {
      btn.disabled = false;
      btn.textContent = I18N.preview;
    });
  });
})();
</script>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Renommer — Radarr{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">Renommer des fichiers</h2>
      </div>
      <div class="col-auto ms-auto">
        {% include 'media/_radarr_nav.html.twig' %}
      </div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
<div class="alert alert-danger">Impossible de joindre Radarr.</div>
{% endif %}

<div class="row g-3">
  <div class="col-12 col-md-4">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Choisir un film</h3>
      </div>
      <div class="card-body">
        <select class="form-select" id="movie-select">
          <option value="">— Sélectionner un film —</option>
          {% for movie in movies %}
          <option value="{{ movie.id }}">{{ movie.title }}{% if movie.year %} ({{ movie.year }}){% endif %}</option>
          {% endfor %}
        </select>
        <div id="proposals-loading" class="text-center mt-3 d-none">
          <div class="spinner-border spinner-border-sm"></div>
          <span class="ms-2 text-muted small">Chargement...</span>
        </div>
      </div>
    </div>
  </div>

  <div class="col-12 col-md-8">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Propositions de renommage</h3>
        <div class="card-options">
          <button id="btn-rename-all" class="btn btn-warning btn-sm d-none">
            Renommer tout
          </button>
        </div>
      </div>
      <div class="card-body" id="proposals-container">
        <div class="text-muted text-center py-5">Sélectionnez un film pour voir les propositions.</div>
      </div>
    </div>
  </div>
</div>

<div id="rename-progress" class="alert alert-info d-none mt-3">
  <div class="d-flex align-items-center gap-2">
    <div class="spinner-border spinner-border-sm"></div>
    <span id="rename-msg">Renommage en cours...</span>
  </div>
</div>

</div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function(){
var currentMovieId = null;

function escapeHtml(str) {
  return String(str).replace(/[&<>"']/g, function(c){
    return c === '&' ? '&amp;' : c === '<' ? '&lt;' : c === '>' ? '&gt;' : c === '"' ? '&quot;' : '&#39;';
  });
}

var movieSelect = document.getElementById('movie-select');
if (movieSelect) {
  movieSelect.onchange = function(e) {
    var id = e.target.value;
    if (!id) {
      document.getElementById('proposals-container').innerHTML = '<div class="text-muted text-center py-5">Sélectionnez un film pour voir les propositions.</div>';
      document.getElementById('btn-rename-all').classList.add('d-none');
      currentMovieId = null;
      return;
    }
    currentMovieId = parseInt(id);
    document.getElementById('proposals-loading').classList.remove('d-none');
    document.getElementById('btn-rename-all').classList.add('d-none');

    fetch('/radarr/renommer/' + id + '/propositions', {
      headers: {'X-Requested-With': 'XMLHttpRequest'}
    }).then(function(r){ return r.json(); }).then(function(proposals){
      document.getElementById('proposals-loading').classList.add('d-none');

      if (!proposals || proposals.length === 0) {
        document.getElementById('proposals-container').innerHTML = '<div class="text-muted text-center py-5">Aucun renommage nécessaire.</div>';
        return;
      }

      document.getElementById('btn-rename-all').classList.remove('d-none');
      var html = '<div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Chemin actuel</th><th>Nouveau chemin</th></tr></thead><tbody>';
      proposals.forEach(function(p) {
        var current = p.existingPath != null ? p.existingPath : '—';
        var newPath = p.newPath != null ? p.newPath : '—';
        var changed = current !== newPath;
        html += '<tr class="' + (changed ? '' : 'text-muted') + '">'
          + '<td class="small text-muted" style="word-break:break-all;max-width:300px">' + escapeHtml(current) + '</td>'
          + '<td class="small fw-medium" style="word-break:break-all;max-width:300px">' + escapeHtml(newPath) + '</td>'
          + '</tr>';
      });
      html += '</tbody></table></div>';
      document.getElementById('proposals-container').innerHTML = html;
    }).catch(function(){
      document.getElementById('proposals-loading').classList.add('d-none');
      document.getElementById('proposals-container').innerHTML = '<div class="alert alert-danger">Erreur lors du chargement.</div>';
    });
  };
}

var btnRenameAll = document.getElementById('btn-rename-all');
if (btnRenameAll) {
  btnRenameAll.onclick = function() {
    if (!currentMovieId) return;
    btnRenameAll.disabled = true;
    var progress = document.getElementById('rename-progress');
    var msg = document.getElementById('rename-msg');
    progress.classList.remove('d-none');
    msg.textContent = 'Lancement du renommage...';

    fetch('/radarr/renommer/' + currentMovieId + '/executer', {
      method: 'POST',
      headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
      body: '{}'
    }).then(function(r){ return r.json(); }).then(function(data){
      if (!data.ok || !data.cmdId) { msg.textContent = 'Erreur.'; return; }

      var poll = setInterval(function() {
        fetch('{{ path('radarr_command_status', {cmdId: '__ID__'}) }}'.replace('__ID__', data.cmdId)).then(function(sr){ return sr.json(); }).then(function(s){
          msg.textContent = 'Renommage : ' + (s.status != null ? s.status : '?');
          if (s.status === 'completed' || s.status === 'failed') {
            clearInterval(poll);
            if (window._prismarrRadarrRenameTimer === poll) window._prismarrRadarrRenameTimer = null;
            btnRenameAll.disabled = false;
            if (s.status === 'completed') msg.textContent = 'Renommage terminé.';
          }
        }).catch(function(){ /* silencieux */ });
      }, 3000);
      window._prismarrRadarrRenameTimer = poll;
    }).catch(function(){
      msg.textContent = 'Erreur réseau.';
    });
  };
}

document.addEventListener('turbo:before-render', function cleanup() {
  if (window._prismarrRadarrRenameTimer) {
    clearInterval(window._prismarrRadarrRenameTimer);
    window._prismarrRadarrRenameTimer = null;
  }
  document.removeEventListener('turbo:before-render', cleanup);
});
})();
</script>
{% endblock %}

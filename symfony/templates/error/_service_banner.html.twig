{#
  Bandeau d'alerte affiché en haut des pages de section quand un service tiers
  n'est pas joignable. Pour le cas "non configuré", le ServiceRouteGuardSubscriber
  redirige en amont vers le wizard donc ce bandeau couvre surtout le cas "configuré
  mais inaccessible" (401, 5xx, timeout…).

  Paramètres attendus :
    service       (string)  — nom lisible (ex: "Radarr")
    wizard_route  (string)  — nom de route Symfony du wizard (ex: "app_setup_managers")
    configured_url (string) — URL configurée (affichée pour aider au diagnostic)
    reason        (?string) — 'unreachable' (défaut) ou 'not_configured'
#}
{% set _reason = reason|default('unreachable') %}
{% set _is_config = _reason == 'not_configured' %}

<div class="alert {{ _is_config ? 'alert-info' : 'alert-danger' }} mb-3" role="alert">
  <div class="d-flex align-items-start gap-3">
    <div class="flex-shrink-0" style="margin-top:2px;">
      {% if _is_config %}
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10.325 4.317c.426 -1.756 2.924 -1.756 3.35 0a1.724 1.724 0 0 0 2.573 1.066c1.543 -.94 3.31 .826 2.37 2.37a1.724 1.724 0 0 0 1.065 2.572c1.756 .426 1.756 2.924 0 3.35a1.724 1.724 0 0 0 -1.066 2.573c.94 1.543 -.826 3.31 -2.37 2.37a1.724 1.724 0 0 0 -2.572 1.065c-.426 1.756 -2.924 1.756 -3.35 0a1.724 1.724 0 0 0 -2.573 -1.066c-1.543 .94 -3.31 -.826 -2.37 -2.37a1.724 1.724 0 0 0 -1.065 -2.572c-1.756 -.426 -1.756 -2.924 0 -3.35a1.724 1.724 0 0 0 1.066 -2.573c-.94 -1.543 .826 -3.31 2.37 -2.37c1 .608 2.296 .07 2.572 -1.065z"/>
          <path d="M9 12l2 2l4 -4"/>
        </svg>
      {% else %}
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="9"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      {% endif %}
    </div>
    <div class="flex-grow-1">
      <h4 class="alert-title mb-1">
        {% if _is_config %}
          {{ service }} n'est pas configuré
        {% else %}
          {{ service }} ne répond pas
        {% endif %}
      </h4>
      <div class="text-muted small mb-2">
        {% if _is_config %}
          Configurez {{ service }} depuis le wizard pour activer cette section.
        {% else %}
          Impossible de contacter
          {% if configured_url is defined and configured_url %}
            <code>{{ configured_url }}</code>
          {% else %}
            le service
          {% endif %}.
          Vérifiez que le service tourne, que l'URL est correcte et que la clé API est valide.
        {% endif %}
      </div>
      <div class="d-flex gap-2">
        {% set _target_route = _is_config ? wizard_route : 'admin_settings_index' %}
        <a href="{{ path(_target_route) }}" class="btn btn-sm {{ _is_config ? 'btn-primary' : 'btn-outline-danger' }}">
          {{ _is_config ? 'Configurer ' ~ service : 'Modifier la configuration' }}
        </a>
        {% if not _is_config %}
          <button type="button" class="btn btn-sm btn-ghost-secondary" onclick="window.location.reload()">
            Réessayer
          </button>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% extends 'base.html.twig' %}

{% block title %}Commandes — Sonarr{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">Commandes</h2>
      </div>
      <div class="col-auto ms-auto">
        {% include 'media/_sonarr_nav.html.twig' %}
      </div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

{% if error %}
<div class="alert alert-danger">Impossible de joindre Sonarr.</div>
{% endif %}

<div id="cmd-feedback" class="alert d-none mb-3"></div>

<div class="card">
  <div class="card-header">
    <h3 class="card-title">Commandes récentes</h3>
    <div class="card-options">
      <span class="badge bg-secondary-lt" id="cmd-count">{{ commands|length }}</span>
      <span class="text-muted small ms-2">Rafraîchi toutes les 5s</span>
    </div>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-vcenter mb-0" id="commands-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Commande</th>
            <th>Statut</th>
            <th>Démarré</th>
            <th>Terminé</th>
            <th>Durée</th>
            <th>Message</th>
            <th class="w-1"></th>
          </tr>
        </thead>
        <tbody id="commands-tbody">
          {% if commands is empty %}
          <tr><td colspan="8" class="text-center text-muted py-4">Aucune commande récente.</td></tr>
          {% else %}
          {% for cmd in commands %}
          <tr>
            <td class="text-muted small">{{ cmd.id }}</td>
            <td class="fw-medium">{{ cmd.name ?? '—' }}</td>
            <td>
              {% set status = cmd.status ?? 'unknown' %}
              {% if status == 'queued' %}
                <span class="badge bg-secondary-lt">En attente</span>
              {% elseif status == 'started' %}
                <span class="badge bg-primary-lt text-primary">En cours</span>
              {% elseif status == 'completed' %}
                <span class="badge bg-success-lt text-success">Terminé</span>
              {% elseif status == 'failed' %}
                <span class="badge bg-danger-lt text-danger">Echoué</span>
              {% else %}
                <span class="badge bg-secondary-lt">{{ status }}</span>
              {% endif %}
            </td>
            <td class="text-muted small">
              {{ cmd.started is defined ? cmd.started|date('H:i:ss') : '—' }}
            </td>
            <td class="text-muted small">
              {{ cmd.ended is defined ? cmd.ended|date('H:i:ss') : '—' }}
            </td>
            <td class="text-muted small">
              {% if cmd.duration is defined %}
                {{ cmd.duration }}
              {% else %}—{% endif %}
            </td>
            <td class="small text-muted" style="max-width:300px;word-break:break-word">
              {{ cmd.message ?? '' }}
              {% if (cmd.status ?? '') == 'failed' and cmd.exception is defined %}
                <span class="text-danger">{{ cmd.exception|slice(0, 150) }}</span>
              {% endif %}
            </td>
            <td>
              {% if status in ['queued', 'started'] %}
              <button class="btn btn-ghost-danger btn-icon btn-sm btn-cmd-cancel"
                      data-id="{{ cmd.id }}"
                      title="Annuler">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6l-12 12m0 -12l12 12"/></svg>
              </button>
              {% endif %}
            </td>
          </tr>
          {% endfor %}
          {% endif %}
        </tbody>
      </table>
    </div>
  </div>
</div>

</div>
</div>
{% endblock %}

{% block javascripts %}
<script>
(function(){
var feedback = document.getElementById('cmd-feedback');
function showFeedback(msg, type) {
  feedback.className = 'alert alert-' + (type || 'success') + ' mb-3';
  feedback.textContent = msg;
  feedback.classList.remove('d-none');
  setTimeout(function(){ feedback.classList.add('d-none'); }, 4000);
}

function bindCancelButtons() {
  document.querySelectorAll('.btn-cmd-cancel').forEach(function(btn) {
    btn.onclick = function() {
      var cmdId = btn.dataset.id;
      if (!confirm('Annuler la commande #' + cmdId + ' ?')) return;
      btn.disabled = true;
      fetch('/sonarr/command/' + cmdId + '/annuler', {
        method: 'POST',
        headers: {'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest'},
        body: '{}'
      }).then(function(r){ return r.json(); }).then(function(data){
        if (data.ok) {
          showFeedback('Commande #' + cmdId + ' annulée.');
          setTimeout(function(){ location.reload(); }, 800);
        } else {
          showFeedback('Erreur lors de l\'annulation.', 'danger');
          btn.disabled = false;
        }
      }).catch(function(){
        showFeedback('Erreur réseau.', 'danger');
        btn.disabled = false;
      });
    };
  });
}
bindCancelButtons();

var refreshTimer = setInterval(function() {
  fetch(window.location.href, {headers: {'X-Requested-With': 'XMLHttpRequest'}}).then(function(r){
    if (!r.ok) return null;
    return r.text();
  }).then(function(html){
    if (!html) return;
    var parser = new DOMParser();
    var doc = parser.parseFromString(html, 'text/html');
    var newTbody = doc.getElementById('commands-tbody');
    var newCount = doc.getElementById('cmd-count');
    if (newTbody) {
      document.getElementById('commands-tbody').innerHTML = newTbody.innerHTML;
      bindCancelButtons();
    }
    if (newCount) {
      document.getElementById('cmd-count').textContent = newCount.textContent;
    }
  }).catch(function(){ /* silencieux */ });
}, 5000);
window._prismarrSonarrCmdTimer = refreshTimer;

document.addEventListener('turbo:before-render', function cleanup() {
  if (window._prismarrSonarrCmdTimer) {
    clearInterval(window._prismarrSonarrCmdTimer);
    window._prismarrSonarrCmdTimer = null;
  }
  document.removeEventListener('turbo:before-render', cleanup);
});
})();
</script>
{% endblock %}

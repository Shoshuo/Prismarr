{% extends 'base.html.twig' %}

{% block title %}{{ 'media.films_history.title'|trans }}{% endblock %}

{% block body %}
<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">{{ 'media.films_history.title'|trans }}</h2>
      </div>
      <div class="col-auto ms-auto">
        {% include 'media/_radarr_nav.html.twig' %}
      </div>
    </div>
  </div>
</div>

<div class="page-body">
<div class="container-xl">

{# Filters by event type #}
<div class="card mb-3">
  <div class="card-body py-2">
    <div class="d-flex align-items-center gap-2 flex-wrap">
      <span class="text-muted small fw-medium">{{ 'media.films_history.filter_label'|trans }}</span>
      {% set eventTypes = [
        {value: '', label: 'media.films_history.event_all'|trans},
        {value: '1', label: 'media.films_history.event_grabbed'|trans},
        {value: '3', label: 'media.films_history.event_imported'|trans},
        {value: '4', label: 'media.films_history.event_failed'|trans},
        {value: '6', label: 'media.films_history.event_deleted'|trans},
        {value: '8', label: 'media.films_history.event_renamed'|trans},
      ] %}
      {% for et in eventTypes %}
        <a href="{{ instance_path('app_media_films_history', {eventType: et.value, page: 1}) }}"
           class="btn btn-sm {{ eventType == et.value ? 'btn-primary' : 'btn-ghost-secondary' }}">
          {{ et.label }}
        </a>
      {% endfor %}
    </div>
  </div>
</div>

{% set records = history.records ?? [] %}
{% set total = history.totalRecords ?? records|length %}

<div class="card">
  <div class="table-responsive">
    <table class="table table-vcenter table-sm card-table">
      <thead>
        <tr>
          <th>{{ 'media.films_history.col_date'|trans }}</th>
          <th>{{ 'media.films_history.col_film'|trans }}</th>
          <th>{{ 'media.films_history.col_event'|trans }}</th>
          <th>{{ 'media.films_history.col_quality'|trans }}</th>
          <th>{{ 'media.films_history.col_source'|trans }}</th>
          <th>{{ 'media.films_history.col_protocol'|trans }}</th>
        </tr>
      </thead>
      <tbody>
      {% for item in records %}
        {% set movie = item.movie ?? null %}
        <tr>
          <td class="text-muted small text-nowrap">
            {% if item.date is defined %}
              {{ item.date|date('d/m/Y H:i') }}
            {% else %}
              —
            {% endif %}
          </td>
          <td>
            {% if movie %}
              <span class="fw-medium">{{ movie.title ?? '—' }}</span>
              {% if movie.year is defined %}<span class="text-muted small ms-1">({{ movie.year }})</span>{% endif %}
            {% else %}
              <span class="text-muted">—</span>
            {% endif %}
          </td>
          <td>
            {% set evType = item.eventType ?? '' %}
            {% if evType == 'grabbed' %}
              <span class="badge bg-primary-lt">{{ 'media.films_history.ev_grabbed'|trans }}</span>
            {% elseif evType == 'downloadFolderImported' %}
              <span class="badge bg-success-lt">{{ 'media.films_history.ev_imported'|trans }}</span>
            {% elseif evType == 'downloadFailed' %}
              <span class="badge bg-danger-lt">{{ 'media.films_history.ev_download_failed'|trans }}</span>
            {% elseif evType == 'movieFileDeleted' %}
              <span class="badge bg-secondary-lt">{{ 'media.films_history.ev_file_deleted'|trans }}</span>
            {% elseif evType == 'movieImported' %}
              <span class="badge bg-success-lt">{{ 'media.films_history.ev_film_imported'|trans }}</span>
            {% elseif evType == 'movieFileRenamed' %}
              <span class="badge bg-blue-lt">{{ 'media.films_history.ev_file_renamed'|trans }}</span>
            {% else %}
              <span class="badge bg-secondary-lt">{{ evType }}</span>
            {% endif %}
          </td>
          <td>
            {% set quality = item.quality.quality.name ?? item.quality ?? null %}
            {% if quality %}
              <span class="badge bg-blue-lt">{{ quality }}</span>
            {% else %}
              <span class="text-muted">—</span>
            {% endif %}
          </td>
          <td class="text-muted small">
            {% set data = item.data ?? {} %}
            {{ data.releaseTitle ?? data.importedPath ?? data.sourceTitle ?? '—' }}
            {% if data.indexer is defined and data.indexer %}
              <br><span class="text-muted" style="font-size:.7rem">{{ data.indexer }}</span>
            {% endif %}
          </td>
          <td class="text-muted small">
            {% set protocol = item.data.protocol ?? item.data.downloadClient ?? null %}
            {{ protocol ?? '—' }}
          </td>
        </tr>
      {% else %}
        <tr>
          <td colspan="6" class="text-center text-muted py-4">{{ 'media.films_history.empty'|trans }}</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>

  {% if total > 50 %}
  <div class="card-footer d-flex align-items-center justify-content-between">
    <p class="m-0 text-muted small">{{ 'media.films_history.pagination_summary'|trans({page: page, count: records|length, total: total}) }}</p>
    <div class="d-flex gap-2">
      {% if page > 1 %}
        <a href="{{ instance_path('app_media_films_history', {page: page - 1, eventType: eventType}) }}" class="btn btn-sm btn-ghost-secondary">{{ 'media.films_history.prev'|trans }}</a>
      {% endif %}
      {% if records|length == 50 %}
        <a href="{{ instance_path('app_media_films_history', {page: page + 1, eventType: eventType}) }}" class="btn btn-sm btn-ghost-secondary">{{ 'media.films_history.next'|trans }}</a>
      {% endif %}
    </div>
  </div>
  {% endif %}
</div>

</div>
</div>
{% endblock %}

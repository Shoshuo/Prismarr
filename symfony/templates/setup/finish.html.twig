{% extends 'setup/_layout.html.twig' %}

{% block title %}{{ 'setup.stepper.finish'|trans }} - Prismarr{% endblock %}

{% block wizard_body %}
  <div class="wizard-eyebrow">{{ 'setup.step.finish.eyebrow'|trans }}</div>
  <h2 class="wizard-title">{{ 'setup.step.finish.title'|trans }}</h2>
  <p class="wizard-subtitle">{{ 'setup.step.finish.subtitle'|trans }}</p>

  <div class="wizard-section">
    {% for service in services %}
      <div class="service-row">
        <div>
          <div class="service-row-name">{{ service.name }}</div>
          {% if service.configured and service.detail %}
            <div class="service-row-sub">{{ service.detail }}</div>
          {% endif %}
        </div>
        {% if service.configured %}
          <span class="service-badge ok">{{ 'setup.step.finish.badge_configured'|trans }}</span>
        {% else %}
          <span class="service-badge skipped">{{ 'setup.step.finish.badge_skipped'|trans }}</span>
        {% endif %}
      </div>
    {% endfor %}
  </div>

  <form action="{{ path('app_setup_finish') }}" method="post" class="mt-4">
    <input type="hidden" name="_csrf_token" value="{{ csrf_token('setup_finish') }}"/>

    <div class="wizard-actions">
      <a href="{{ path('app_setup_downloads') }}" class="btn-wizard-back">{{ 'setup.step.common.back'|trans }}</a>
      <button type="submit" class="btn-wizard-next">
        {{ 'setup.step.finish.cta'|trans }}
      </button>
    </div>
  </form>
{% endblock %}

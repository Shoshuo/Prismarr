{% extends 'setup/_layout.html.twig' %}

{% block title %}{{ 'setup.step.welcome.title'|trans }} - Prismarr{% endblock %}

{% block wizard_body %}
  <div class="welcome-hero">
    <img src="{{ asset('img/prismarr/prismarr-icon-512.png') }}" alt=""/>
    <h1 class="welcome-title">{{ 'setup.step.welcome.title'|trans }}</h1>
    <p class="welcome-subtitle">{{ 'setup.step.welcome.subtitle'|trans }}</p>

    <div class="welcome-features">
      <div class="welcome-feature">
        <div class="welcome-feature-icon">🎬</div>
        <div>{{ 'setup.step.welcome.features.media'|trans }}</div>
      </div>
      <div class="welcome-feature">
        <div class="welcome-feature-icon">🔎</div>
        <div>{{ 'setup.step.welcome.features.indexers'|trans }}</div>
      </div>
      <div class="welcome-feature">
        <div class="welcome-feature-icon">⬇️</div>
        <div>{{ 'setup.step.welcome.features.downloads'|trans }}</div>
      </div>
      <div class="welcome-feature">
        <div class="welcome-feature-icon">✨</div>
        <div>{{ 'setup.step.welcome.features.discovery'|trans }}</div>
      </div>
    </div>
  </div>

  <div class="wizard-actions">
    <span></span>
    <a href="{{ path('app_setup_admin') }}" class="btn-wizard-next">
      {{ 'setup.step.welcome.cta'|trans }}
    </a>
  </div>
{% endblock %}
